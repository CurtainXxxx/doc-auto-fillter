# 外部模型API配置（填好后保存为 .env 文件）
# 设置后Agent将使用外部模型，不设置则使用平台内置模型

# === DeepSeek ===
EXTERNAL_LLM_API_KEY=sk-你的deepseek密钥
EXTERNAL_LLM_BASE_URL=https://api.deepseek.com
EXTERNAL_LLM_MODEL=deepseek-chat

# === 硅基流动 SiliconFlow ===
# EXTERNAL_LLM_API_KEY=sk-你的密钥
# EXTERNAL_LLM_BASE_URL=https://api.siliconflow.cn/v1
# EXTERNAL_LLM_MODEL=Qwen/Qwen3-235B-A22B

# === 智谱 GLM ===
# EXTERNAL_LLM_API_KEY=你的密钥
# EXTERNAL_LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# EXTERNAL_LLM_MODEL=glm-4-plus
