# ============================================================
# 外部模型API配置
# 三种模式，只需配置一种即可，优先级从上到下：
#   1. Anthropic Claude（原生API）
#   2. OpenAI兼容外部API（DeepSeek / OpenRouter / 硅基流动等）
#   3. 不配置则使用平台内置模型（doubao-seed）
# ============================================================

# --- 模式1: Anthropic Claude ---
# 获取API Key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-你的密钥
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- 模式2: OpenAI兼容外部API ---

# DeepSeek
# EXTERNAL_LLM_API_KEY=sk-你的deepseek密钥
# EXTERNAL_LLM_BASE_URL=https://api.deepseek.com
# EXTERNAL_LLM_MODEL=deepseek-chat

# OpenRouter（可访问Claude/GPT/Gemini等数百种模型）
# 注册: https://openrouter.ai/
# EXTERNAL_LLM_API_KEY=sk-or-你的openrouter密钥
# EXTERNAL_LLM_BASE_URL=https://openrouter.ai/api/v1
# EXTERNAL_LLM_MODEL=anthropic/claude-sonnet-4

# 硅基流动
# EXTERNAL_LLM_API_KEY=sk-你的硅基流动密钥
# EXTERNAL_LLM_BASE_URL=https://api.siliconflow.cn/v1
# EXTERNAL_LLM_MODEL=Qwen/Qwen3-235B-A22B

# 智谱GLM
# EXTERNAL_LLM_API_KEY=你的智谱密钥
# EXTERNAL_LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# EXTERNAL_LLM_MODEL=glm-4-plus
